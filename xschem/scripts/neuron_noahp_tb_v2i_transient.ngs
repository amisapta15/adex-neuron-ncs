"
.param temp=27
.param Iin_amp=2n

.ic V(vmem)=0 V(xneuron.xref.vref)=0 V(REQ)=1.2 V(ACK)=1.2

.options gmin=1e-13
.control

save V(I_lk) V(I_in) I(Viinprob)
